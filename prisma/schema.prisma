// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["strictUndefinedChecks"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id      Int      @id @default(autoincrement())
  name    String
  reviews Review[]
}

model Review {
  id      Int      @id @default(autoincrement())
  rating  Int
  comment String?
  posted  DateTime
  // We assume that the review is for the latest serving.
  // Personally I find it confusing and a bit overwhelming
  // if the UI handles different servings of the same lunch
  // as different lunches cluttering the UI and making our
  // users lifes and ours harder. We just assume it's a review
  // for the latest servings.
  lunchId Int
  lunch   Lunch    @relation(fields: [lunchId], references: [id])
  userId  Int?
  user    User?    @relation(fields: [userId], references: [id])
}

model Lunch {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  eco_score   Float
  ingredients Ingredient[]
  servings    DateTime[]
  reviews     Review[]
}

model Ingredient {
  id      Int    @id @default(autoincrement())
  name    String
  unit    String
  amount  Float
  lunchId Int
  lunch   Lunch  @relation(fields: [lunchId], references: [id])
}
